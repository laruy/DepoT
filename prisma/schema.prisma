generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  MEMBER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  users    User[]
  invites  Invite[]
  features Feature[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  accounts      Account[]
  sessions      Session[]
  role         Role     @default(MEMBER)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  testCasesCreated TestCase[] @relation("CreatedBy")
  invitesSent      Invite[]   @relation("InvitedBy")

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime
  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Invite {
  id        String    @id @default(cuid())
  token     String    @unique
  email     String
  used      Boolean   @default(false)
  createdAt DateTime  @default(now())
  expiresAt DateTime?

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  invitedById String?
  invitedBy   User?   @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([email])
}

model Feature {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#A78BFA")
  maestroTags String? // tags maestro associadas a esta feature, separadas por vírgula
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  testCases     TestCase[]
  automationDoc AutomationDoc?

  @@index([workspaceId])
}

model TestCase {
  id              String   @id @default(cuid())
  title           String
  description     String?
  steps           String? // passo a passo, texto livre (uma linha por passo)
  expectedResult  String?
  priority        Priority @default(MEDIUM)
  isAutomated     Boolean  @default(false)
  automationTags  String? // tags maestro específicas deste caso (opcional, além das da feature)
  automationNotes String? // observações específicas sobre a automação deste caso
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  featureId String
  feature   Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  createdById String?
  createdBy   User?   @relation("CreatedBy", fields: [createdById], references: [id])

  @@index([featureId])
}

model AutomationDoc {
  id          String   @id @default(cuid())
  content     String   @default("") // markdown: como a automação desta feature funciona
  updatedAt   DateTime @updatedAt

  featureId String  @unique
  feature   Feature @relation(fields: [featureId], references: [id], onDelete: Cascade)
}
